# Recommended layered configuration: text planning/replan and screenshot vision
# use independent OpenAI-compatible providers.
TEXT_LLM_API_KEY=your_text_llm_key
TEXT_LLM_MODEL=deepseek-chat
TEXT_LLM_BASE_URL=https://api.deepseek.com

VISION_LLM_API_KEY=your_vision_llm_key
VISION_LLM_MODEL=qwen3-vl-flash
VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Qwen-VL uses a normalized 0-1000 grounding grid. Auto-detected by model name;
# set this only to override another provider's convention.
# VISION_LLM_COORDINATE_SPACE=normalized_1000

# Optional per-layer request controls:
# TEXT_LLM_TIMEOUT_SECONDS=90
# TEXT_LLM_MAX_RETRIES=1
# VISION_LLM_TIMEOUT_SECONDS=90
# VISION_LLM_MAX_RETRIES=1

# Legacy single-provider variables remain supported for text-only usage:
# OPENAI_API_KEY=your_api_key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=
#
# Other legacy OpenAI-compatible alternatives:
# DeepSeek:
# DEEPSEEK_API_KEY=your_deepseek_key
# DEEPSEEK_MODEL=deepseek-chat
# BASE_URL=https://api.deepseek.com
#
# Alibaba Cloud DashScope compatible mode:
# DASHSCOPE_API_KEY=your_dashscope_key
# DASHSCOPE_MODEL=qwen-plus
# BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

BROWSER_TYPE=chrome
BROWSER_PATH=/usr/bin/google-chrome
BROWSER_USER_DATA_PATH=outputs/browser_profiles/chrome
BROWSER_DEBUG_PORT=19222
BROWSER_HEADLESS=0
OUTPUT_DIR=outputs
